# Required: OpenRouter API key for AI features (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Optional: Upstash Redis for caching (get from https://console.upstash.com)
# Falls back to in-memory cache if not set
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Supabase for auth (get from https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: NewsData.io for additional news (get from https://newsdata.io/register)
NEWSDATA_API_KEY=

# Optional: Base URL for SEO sitemap
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app
